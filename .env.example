# Environment Configuration for Intelligent Invoicing System
# Copy this file to .env and update the values

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
NODE_ENV=development
TIMEZONE=UTC

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intelligent_invoicing
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================
PORT=3001
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Logging
LOG_LEVEL=info

# =============================================================================
# AI SERVICES CONFIGURATION
# =============================================================================
# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4000

# =============================================================================
# GOOGLE SERVICES CONFIGURATION
# =============================================================================
# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-for-invoices

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM="Intelligent Invoicing <noreply@yourdomain.com>"

# =============================================================================
# N8N WORKFLOW ENGINE CONFIGURATION
# =============================================================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=your-n8n-encryption-key-change-in-production
WEBHOOK_URL=http://localhost:5678
N8N_LOG_LEVEL=info

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME=Intelligent Invoicing
VITE_APP_VERSION=1.0.0
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
# Local file storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# AWS S3 (optional)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=

# Google Analytics
GOOGLE_ANALYTICS_ID=

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
# Enable debug modes
DEBUG_SQL=false
DEBUG_ROUTES=false
DEBUG_AUTH=false

# Hot reload
WATCH_FILES=true

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# Set these for production deployment
DOMAIN=yourdomain.com
SSL_ENABLED=true
CLUSTER_MODE=true
WORKERS=auto

# Database connection pooling for production
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=300000

# CDN Configuration
CDN_URL=https://cdn.yourdomain.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_AI_PROCESSING=true
FEATURE_BATCH_UPLOAD=true
FEATURE_ANALYTICS=true
FEATURE_NOTIFICATIONS=true
FEATURE_AUDIT_LOG=true
FEATURE_MULTI_CURRENCY=false
FEATURE_MULTI_LANGUAGE=false

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Stripe for payments (optional)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Slack notifications (optional)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# Twilio for SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=