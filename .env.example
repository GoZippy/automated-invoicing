# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=invoicing
POSTGRES_USER=invoicing
POSTGRES_PASSWORD=changeme

# n8n
N8N_ENCRYPTION_KEY=replace-with-32-char-secret
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=adminpass
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_LOG_LEVEL=info

# n8n DB config
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=${POSTGRES_HOST}
DB_POSTGRESDB_PORT=${POSTGRES_PORT}
DB_POSTGRESDB_DATABASE=${POSTGRES_DB}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}

# Providers
OPENAI_API_KEY=
# Path inside container for n8n to read; mount your credentials file there if needed
GOOGLE_APPLICATION_CREDENTIALS=/home/node/.gcp/credentials.json

# Webhook client testing
WEBHOOK_URL=http://localhost:5678/webhook/<your-path>
X_API_KEY=
HMAC_SECRET=