# Test Environment Variables
NODE_ENV=test
PORT=3001

# Supabase Test Configuration
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key
SUPABASE_ANON_KEY=test-anon-key

# JWT Test Configuration
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=test-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI Test Configuration
OPENAI_API_KEY=test-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Google Vision Test Configuration
GOOGLE_VISION_CREDENTIALS={}
GOOGLE_VISION_PROJECT_ID=test-project

# Email Test Configuration (Mailhog)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=test@example.com
EMAIL_PASS=test-password
EMAIL_FROM=noreply@test.com
EMAIL_SECURE=false

# Rate Limiting Test Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=100

# File Upload Test Configuration
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Redis Test Configuration (optional)
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# Logging Test Configuration
LOG_LEVEL=error
LOG_FILE_PATH=./logs/test.log
LOG_MAX_FILES=1
LOG_MAX_SIZE=5m

# CORS Test Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# API Keys Test Configuration
API_KEY_PREFIX=test_
API_KEY_SALT_ROUNDS=10

# Webhook Test Configuration
WEBHOOK_SECRET=test-webhook-secret
WEBHOOK_TIMEOUT=5000

# Monitoring Test Configuration
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_OCR=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WEBHOOKS=true